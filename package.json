{
  "name": "hydrate",
  "displayName": "Hydrate",
  "description": "Stay hydrated while coding. Receive smart reminders, earn XP, build streaks, unlock achievements, and level up your hydration habits.",
  "publisher": "pratik-pawar",
  "license": "MIT",
  "version": "0.1.0",
  "icon": "icon.png",

  "engines": {
    "vscode": "^1.120.0"
  },

  "categories": [
    "Other"
  ],

  "keywords": [
    "water",
    "hydration",
    "health",
    "productivity",
    "reminder",
    "wellness",
    "gamification",
    "xp",
    "streak",
    "achievements"
  ],

  "activationEvents": [
    "onStartupFinished"
  ],

  "main": "./extension.js",

  "contributes": {
    "commands": [
      {
        "command": "hydrate.start",
        "title": "Hydrate: Start Timer"
      },
      {
        "command": "hydrate.stop",
        "title": "Hydrate: Stop Timer"
      },
      {
        "command": "hydrate.reset",
        "title": "Hydrate: Reset Timer"
      },
      {
        "command": "hydrate.showStats",
        "title": "Hydrate: Show Stats"
      },
      {
        "command": "hydrate.showAchievements",
        "title": "Hydrate: Show Achievements"
      }
    ],

    "configuration": {
      "title": "Hydrate",
      "properties": {
        "hydrate.reminderInterval": {
          "type": "number",
          "default": 60,
          "minimum": 1,
          "description": "How often to remind you to drink water (in minutes)"
        },

        "hydrate.reminderMessage": {
          "type": "string",
          "default": "Time to hydrate!",
          "description": "Custom hydration reminder message"
        }
      }
    }
  },

  "repository": {
    "type": "git",
    "url": "https://github.com/PratikP06/Hydrate"
  },

  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },

  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  }
}